# ── Google OAuth ──────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── App ───────────────────────────────────────────────────
# In production (Railway) this is your deployed URL, e.g. https://taskflow-production.up.railway.app
APP_URL=http://localhost:4000
PORT=4000

# ── Session ───────────────────────────────────────────────
SESSION_SECRET=change-me-to-a-long-random-string

# ── Team Access ───────────────────────────────────────────
# Comma-separated list of Google emails allowed to log in
ALLOWED_EMAILS=person1@gmail.com,person2@gmail.com,person3@gmail.com
